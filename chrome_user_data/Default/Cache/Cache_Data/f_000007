_ai.template = {
    parseObject : function (templateId, data) {
        var tmpl = $("#"+templateId).text();
        if(data != null) {
            try {
                Object.keys(data).forEach(function(k){
                    tmpl = tmpl.replace(new RegExp("#"+k+"#", "gi"), data[k]);
                });
            } catch (E) {
                log.error(E);
            }
        }
        return tmpl;
    }, parseMessage : function(message, data) {
        if(data != null) {
            try {
                Object.keys(data).forEach(function(k){
                    message = message.replace(new RegExp("#"+k+"#", "gi"), data[k]);
                });
            } catch (E) {
                log.error(E);
            }
        }
        return message;
    }, parseList : function (templateId, list) {
        var r = [];
        if(list != null && list.length > 0) {
            list.forEach(function(o){
                r.push(_ai.template.parseObject(templateId, o));
            });
        }
        return r;
    }
}

_ai.sortTable = {
    renderPage: function() {
        // 화살표 추가
        const htmlStr = `<div class="sorting-wrap"><span></span><div class="sorting"><button type="button" class="sorting-up" data-sortype="asc" onclick="_ai.sortTable.click(this)"></button><button type="button" class="sorting-down" data-sortype="desc" onclick="_ai.sortTable.click(this)"></button></div></div>`;

        let titleArr = [];

        document.querySelectorAll('.sort').forEach(function(e) {
            let title = e.innerText;
            e.innerHTML = htmlStr;
            titleArr.push(title);
        });

        let sp = document.querySelectorAll('.sort span');
        sp.forEach(function(e, i) {
            e.innerText = titleArr[i];
        });
    }, click: function() {
        console.log('override function _ai.sortTable.click()');
    }, getParameters: function(e) {
        let isSelected = false;
        if (e.classList.contains('on')) {
            isSelected = true;
        }
        let type = e.parentNode.parentNode.parentNode.parentNode.dataset['type'];
        _ai.sortTable.changeStyle(e, isSelected, type);
        if (isSelected) {
            return ['asc', null, type];
        } else {
            let sortType = e.dataset['sortype'];
            let sortColumn = e.parentNode.parentNode.parentNode.dataset['column'];
            return [sortType, sortColumn, type];
        }
    }, changeStyle: function(e, isSelected, type) {
        let btnType = e.dataset['sortype'];
        let str = `[data-type='${type}'] .sorting button`;
        document.querySelectorAll(str).forEach((e1) => {
            e1.classList.remove('on');
        });
        if (!isSelected) {
            if (btnType == 'asc') {
                e.classList.value = 'sorting-up on';
            } else {
                e.classList.value = 'sorting-down on';
            }
        }
    }, _resetStyle : function(type){
        let str = `[data-type='${type}'] .sorting button`;
        document.querySelectorAll(str).forEach((e) => {
            e.classList.remove('on');
        });
    }
}
