        return moment().format('YYYYMMDDHHmmssSSS');
    },
    getLastKey : function() {
        let keys = this.keySet();
        return keys[keys.length - 1];
    },
    getLastData : function() {
        let keys = this.keySet();
        return this.get(keys[keys.length - 1]);
    },
