_ai.util = {
    changeLocale : function(locale) {
        _ai.cookie.set('lang', locale);
        window.location.reload();
    }
    , getUrlParams : function() {
        var params = {};
        window.location.search.replace(/[?&]+([^=&]+)=([^&]*)/gi, function (str, key, value) {
            params[key] = value;
        });

        return params;
    }
    , hasUrlParam: function(key) {
        let returnVal = false;

        let url = document.location.href;
        let qs = url.substring(url.indexOf('?') + 1).split('&');
        for (var i = 0; i < qs.length; i++) {
            let paramInfoArr = qs[i].split('=');
            if (paramInfoArr && paramInfoArr[0] == key) {
                returnVal = true;
            }
        }

        return returnVal;
    }
    , getHashParam : function() {
        var hash = window.location.hash;
        if(_ai.common.isNotBlank(hash)) {
            return hash.substr(1);
        }
    }
    , hasHashParam : function(key) {
        var hashParam = _ai.util.getHashParam();
        if(key == hashParam) {
            return true;
        } else {
            return false;
        }
    }
    , gotoMenuPage : function(url) {
        if (document.location.href.includes(url)) {
            document.location.href = url + '#init';
            document.location.reload();
        } else {
            document.location.href = url + '#init';
        }
    }
}

_ai.pager = {
    PAGE_CLICK_CALLBACK_MAP : new HashMap()
    , renderPager : function(page, pageId = "pager"){
        let $pageId = $("#" + pageId);
        $pageId.empty();

        if(page.lastPage >= page.startPage) {
            if(page.nowPageGroup > 1){
                $pageId.append(`<button type="button" class="firstPage" onclick="javascript:_ai.pager._click('1','${pageId}'); return false;"><span class="blind">firstPage</span></button>`);
                $pageId.append(`<button type="button" class="prevPage" onclick="javascript:_ai.pager._click('${page.startPage - 1}','${pageId}'); return false;"><span class="blind">prevPage</span></button>`);
            }

            $pageId.append(`<div class="paging-list">`);
            for(var i = page.startPage; i < (page.endPage + 1); i++) {
                if(i == page.pageIndex) {
                    $pageId.append(`<button type="button" class="paging-item on" onclick="javascript:_ai.pager._click('${i}','${pageId}'); return false;">${i}</button>`);
                } else {
                    $pageId.append(`<button type="button" class="paging-item" onclick="javascript:_ai.pager._click('${i}','${pageId}'); return false;">${i}</button>`);
                }
            }
            $pageId.append(`</div>`);

            if(page.lastPage >= page.nextGroupIndex && (page.startPage + page.pageGroupSize) <= page.lastPage) {
                $pageId.append(`<button type="button" class="nextPage" onclick="javascript:_ai.pager._click('${page.nextGroupIndex}','${pageId}'); return false;"><span class="blind">nextPage</span></button>`);
                $pageId.append(`<button type="button" class="lastPage" onclick="javascript:_ai.pager._click('${page.lastPage}','${pageId}'); return false;"><span class="blind">lastPage</span></button>`);
            }
        }
    }
    , click : function(){
        console.log("override function _ai.pager.click()");
    }
    , setPagerClick : function(pageId = "pager", callback) {
        if(_ai.common.isNotEmpty(callback) && typeof callback === "function") {
            _ai.pager.PAGE_CLICK_CALLBACK_MAP.put(pageId, callback);
        }
    }
    , _click : function(pageIndex, pageId) {
        if(!_ai.pager.PAGE_CLICK_CALLBACK_MAP.isEmpty() && _ai.common.isNotEmpty(_ai.pager.PAGE_CLICK_CALLBACK_MAP.get(pageId))){
            console.log("pager click in map");
            _ai.pager.PAGE_CLICK_CALLBACK_MAP.get(pageId)(pageIndex);
        } else {
            console.log("pager click using override");
            _ai.pager.click(pageIndex);
        }
    }
}

