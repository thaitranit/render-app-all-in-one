            // 모든 드래그 가능한 행에 대한 설정
            document.querySelectorAll('.dndTable tbody tr').forEach((el) => {
                el.addEventListener('dragend', () => {
                    // 드래그 종료 시 'dragging' 클래스 제거 및 드래그 비활성화
                    el.classList.remove('dragging');
                    el.draggable = false;
                });
            });
        },
        dragHandle: function (e) {
            // 드래그 핸들 클릭 시 행을 드래그 가능하게 설정하고 'dragging' 클래스 추가
            const row = e.target.parentNode.parentNode.parentNode;

            row.classList.add('dragging');
            row.draggable = true;
        },
        dropzone: function (e) {
            const dropzone = e.currentTarget;
            e.preventDefault();
    
            // 드래그 오버 이벤트 처리
            const afterElement = this.getDragAfterElement(dropzone, e.clientY);
            const draggable = document.querySelector('.dragging');

            if (afterElement === null) {
                // 마지막 위치에 추가
                dropzone.appendChild(draggable);
            } else {
                // 특정 위치에 삽입
                dropzone.insertBefore(draggable, afterElement);
            }
        },
        getDragAfterElement: function (container, y) {
            // 드래그 가능한 요소들을 선택 (드래그 중인 요소는 제외)
            const draggableElements = [...container.querySelectorAll('tr:not(.dragging)')];
        
            // 드래그한 위치와 가장 가까운 요소를 찾음
            return draggableElements.reduce((closest, child) => {
                const box = child.getBoundingClientRect();
                const offset = y - box.top - box.height / 2;
        
                if (offset < 0 && offset > closest.offset) {
                    return { offset: offset, element: child };
                } else {
                    return closest;
                }
            }, { offset: Number.NEGATIVE_INFINITY }).element;
        },
    },
    colorPicker : {
