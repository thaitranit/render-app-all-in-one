            const fileName = uploadInput.nextElementSibling;

            uploadInput.addEventListener('change', (e) => {
                if (fileName.tagName === 'BUTTON') {
                    fileName.textContent = uploadInput.files[0].name;
                } else if (fileName.tagName === 'INPUT') {
                    fileName.value = uploadInput.files[0].name;
                }

                if (uploadInput.parentElement.firstElementChild.tagName === 'IMG') {
                    const file = e.target.files[0];
                    const IMG_URL = URL.createObjectURL(file);
                    uploadInput.parentElement.firstElementChild.setAttribute('src', `${IMG_URL}`);
                }
            });
        },
        getData : function(inputId) {
            const uploadInput = document.querySelector(`#${inputId}`);

            return uploadInput.value;
        },
        delete : function(inputId) {
            const uploadInput = document.querySelector(`#${inputId}`);
            const fileName = uploadInput.nextElementSibling;

            uploadInput.value = null;
            if (fileName.tagName === 'BUTTON') {
                fileName.textContent = uploadInput.value;
            } else if (fileName.tagName === 'INPUT') {
                fileName.value = uploadInput.value;
            }
        }
    },
