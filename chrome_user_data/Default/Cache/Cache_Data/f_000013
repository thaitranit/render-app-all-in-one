        const name = 'Message';
        const popupWidth = 900;
        const popupHeight = 720;
        const posX = window.innerWidth/2 - popupWidth/2;
        const posY = window.innerHeight/2 - popupHeight/2;
        const option = `width=${popupWidth}, height=${popupHeight}, top=${posY}, left=${posX}`;
        
        window.open(url, name, option);
    },
